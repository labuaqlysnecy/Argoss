# Скопируйте этот файл в .env и заполните свои значения:
#   cp .env.example .env

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# API-ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama (локальный LLM)
# Лёгкая модель для слабых машин; замените на llama3:8b или другую при наличии ресурсов
OLLAMA_MODEL=llama3.2:1b
# Таймаут (сек) ожидания ответа от Ollama (по умолчанию 600)
OLLAMA_TIMEOUT=600

# Режим ИИ: auto — автоматический выбор (ollama → gemini → gpt → etc.)
ARGOS_AI_MODE=auto

# Grist P2P-хранилище (https://getgrist.com / self-hosted)
# API-ключ Grist (Settings → API key)
GRIST_API_KEY=your_grist_api_key_here
# URL сервера Grist (по умолчанию https://docs.getgrist.com)
GRIST_SERVER_URL=https://docs.getgrist.com
# ID документа Grist (из URL: /doc/<DOC_ID>).
GRIST_DOC_ID=your_grist_doc_id_here
# Альтернатива GRIST_DOC_ID: задайте одно из двух, GIST_ID используется только если GRIST_DOC_ID не задан.
# GIST_ID=your_grist_doc_id_here
# Шифрование записей перед сохранением в Grist: on / off (по умолчанию on)
GRIST_ENCRYPT=on
